[include]
    path = ~/.private/gitidentity

# Machine-specific SSH config.
# Discriminate by absolute path; all repos are in home dirs
# 
#   macOS  -> /Users/<user>/...
#   WSL    -> /home/<user>/...  # note this isn't going to work for non-WSL but a bridge to cross later
#   W11    -> C:/Users/<user>/...
#
# Crude, but works to stratify custom setup for now; will make more sophisticated
# if required

[includeIf "gitdir:/home/"]
    path = ~/.private/gitssh.wsl

#[includeIf "gitdir:/Users/"]
#    path = ~/.private/gitssh.macos
#
#[includeIf "gitdir:C:/Users/"]
#    path = ~/.private/gitssh.win

[core]
    autocrlf = input
    safecrlf = true
    attributesfile = ~/.config/git/attributes
    excludesfile = ~/.config/git/ignore
    pager = less -x1,5
[alias]
    # actively used
    go = checkout
    hist = log --pretty=format:'%C(auto)%h %ad |%d %s [%an]' --graph --date=short

    # incubation/trial
    ls-branch = !git --no-pager diff --name-status "$(git merge-base HEAD main)" HEAD

    # rarely used
    co = commit
    ci = commit
    st = status
    br = branch
    cp = cherry-pick -x
    type = cat-file -t
    dump = cat-file -p
    uncommit = reset --soft HEAD^1
    unstage = reset --mixed HEAD
    rewind-commit = reset --soft HEAD^1
    rewind-index = reset --mixed HEAD^1
    rewind-files = reset --hard HEAD^1
    wdiff = diff --color-words
    addnw=!sh -c 'git diff -U0 -w --no-color --src-prefix=a/ --dst-prefix=b/ "$@" | git apply --cached --ignore-whitespace --unidiff-zero -'
[color]
    diff = auto
    status = auto
    branch = auto
    interactive = auto
    ui = auto
[filter "tabspace"]
    smudge = unexpand --tabs=4 --first-only
    clean = expand --tabs=4 --initial
[push]
    default = current
	autoSetupRemote = true
[merge]
	tool = vimdiff
[init]
	defaultBranch = main
[mergetool "vimdiff"]
	path = /home/alex/app/nvim.appimage
[lfs "customtransfer.xet"]
	path = git-xet
	args = transfer
	concurrent = true
